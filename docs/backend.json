
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific metadata and study preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email" },
        "mobileNumber": { "type": "string", "description": "User's mobile contact number." },
        "collegeName": { "type": "string", "description": "The medical college or university name." },
        "currentYear": { 
          "type": "string", 
          "enum": ["1st Year", "2nd Year", "3rd Year (Part 1)", "4th Year (Part 2)", "Internship"],
          "description": "The user's current academic year in MBBS."
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin"],
          "description": "The user's role in the system for access control."
        },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "currentYear", "role"]
    },
    "MedicalSubject": {
      "title": "Medical Subject",
      "description": "A top-level medical subject like Anatomy or Pathology.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "iconName": { "type": "string" },
        "color": { "type": "string" },
        "unitCount": { "type": "number" },
        "topicCount": { "type": "number" }
      },
      "required": ["name", "iconName"]
    },
    "MedicalTopic": {
      "title": "Medical Topic",
      "description": "A specific study topic within a subject.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "title": { "type": "string" },
        "contentUrl": { "type": "string", "description": "URL to the file in Firebase Storage." },
        "contentType": { "type": "string", "enum": ["pdf", "video", "image", "csv"] },
        "importance": { "type": "string", "enum": ["Low", "Medium", "High", "Essential"] },
        "readTime": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] }
      },
      "required": ["subjectId", "title", "contentType"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/subjects/{subjectId}": {
      "schema": "MedicalSubject",
      "description": "Root subjects for the medical library."
    },
    "/subjects/{subjectId}/topics/{topicId}": {
      "schema": "MedicalTopic",
      "description": "Topics and resources within a subject."
    }
  }
}
